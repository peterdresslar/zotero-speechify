{
  "manifest_version": 3,
  "name": "Zotero Speechify",
  "version": "0.1.0",
  "description": "Unofficial voice controls for the Zotero Web reader.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Zotero Speechify",
    "default_popup": "src/entries/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_page": "src/entries/options/index.html",
  "permissions": ["activeTab", "offscreen", "storage"],
  "host_permissions": [
    "https://www.zotero.org/*/items/*/reader*",
    "https://www.zotero.org/*/items/*/attachment/*/reader*",
    "https://www.zotero.org/*/collections/*/items/*/reader*",
    "https://www.zotero.org/*/collections/*/items/*/attachment/*/reader*",
    "https://api.zotero.org/*",
    "https://api.speechify.ai/*"
  ],
  "background": {
    "service_worker": "assets/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zotero.org/*/items/*/reader*",
        "https://www.zotero.org/*/items/*/attachment/*/reader*",
        "https://www.zotero.org/*/collections/*/items/*/reader*",
        "https://www.zotero.org/*/collections/*/items/*/attachment/*/reader*"
      ],
      "js": ["assets/reader-control.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "say-selected-text": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Say selected Zotero text"
    },
    "voice-annotate": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "MacCtrl+Shift+A"
      },
      "description": "Start voice annotation"
    }
  }
}
